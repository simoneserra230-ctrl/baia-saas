# ══════════════════════════════════════════════════════════
# BA.IA — Configurazione Produzione
# Copia in .env nella stessa cartella di docker-compose.prod.yml
# ══════════════════════════════════════════════════════════

# ── OBBLIGATORI ────────────────────────────────────────────

# Il dominio che hai puntato a questo server (es. baia.miostudio.it)
# Caddy otterrà automaticamente un certificato HTTPS Let's Encrypt
DOMAIN=tuodominio.it

# Chiave API Groq (gratuita su https://console.groq.com)
GROQ_API_KEY=gsk_INSERISCI_LA_TUA_CHIAVE

# ── OPZIONALI ──────────────────────────────────────────────

# Branding
APP_NAME=BA.IA

# Licenza — in produzione usa una chiave reale
LICENSE_KEY=TEST-MODE

# Provider AI alternativi (lascia vuoto per usare Groq)
AI_PROVIDER=groq
AI_API_KEY=
AI_MODEL=

# SMTP per email automatiche
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@baia.it
